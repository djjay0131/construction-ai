# Backend Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=sqlite:///./construction_ai.db

# Gemini API (for scale detection and OCR enhancement)
# Get your key from https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# YOLO Model Paths (relative to backend directory)
YOLO_BOUNDARY_MODEL_PATH=../datascience/runs/yolo12xtrain_floorplan_boundary/yolo12x_floorplan_boundary_exp2/weights/best.pt
YOLO_OBJECT_MODEL_PATH=../datascience/runs/yolo12xtrain/yolo12x_exp3/weights/best.pt

# PDF Processing
PDF_DPI=300
# POPPLER_PATH=/usr/bin  # Uncomment if poppler not in PATH

# File Upload
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE=104857600  # 100 MB in bytes

# API Keys (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Debug
DEBUG=False

