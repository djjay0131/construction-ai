# Application
APP_NAME=Construction AI
APP_VERSION=0.1.0
DEBUG=true

# Database
DATABASE_URL=sqlite:///./construction_ai.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/construction_ai

# Redis & Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# File Upload
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE=104857600
ALLOWED_EXTENSIONS=.dwg,.dxf,.pdf,.png,.jpg,.jpeg

# LLM APIs (optional - add your keys)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# YOLO Model
YOLO_MODEL_PATH=./ml/yolo/models/best.pt
YOLO_CONFIDENCE_THRESHOLD=0.5

# Material Calculation Defaults
DEFAULT_STUD_SPACING_INCHES=16
STANDARD_LUMBER_LENGTHS=96,120,144,168,192,240

# Optimization
CUT_OPTIMIZATION_KERF=0.125
